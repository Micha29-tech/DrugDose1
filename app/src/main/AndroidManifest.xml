<?xml version="1.0" encoding="utf-8"?>
<!--
    AndroidManifest.xml
    Dichiara:
    1. Il nome del package dell'app
    2. Tutti i componenti Android (Activity, Service, BroadcastReceiver, ContentProvider)
    3. I permessi richiesti dall'app
    4. Informazioni per il Play Store (icona, tema, versione)
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
        FOREGROUND_SERVICE: permesso normale — obbligatorio per chiamare startForeground()
        POST_NOTIFICATIONS: permesso pericoloso su Android 13+ — deve essere chiesto
            a runtime con requestPermissions() (lo fa il nostro CalculatorFragment)
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".DrugDoseApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.DrugDose1"
        tools:targetApi="31">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>


        <service
            android:name=".service.DoseReminderService"
            android:exported="false"/>

    </application>
</manifest>