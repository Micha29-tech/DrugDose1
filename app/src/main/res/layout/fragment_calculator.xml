<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/margin_medium">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/content_description_back_to_drugs"
            android:padding="12dp"
            android:src="@drawable/ic_arrow_back" />

        <!-- Card farmaco selezionato (header della schermata) -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.DrugDose1.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/margin_medium">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_card">
                <TextView
                    android:id="@+id/tv_calc_drug_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_size_subtitle"
                    android:textStyle="bold"
                    android:textColor="@color/color_primary" />
                <TextView
                    android:id="@+id/tv_calc_indication"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_tiny"
                    android:textSize="@dimen/text_size_body"
                    android:textColor="@color/color_text_secondary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_weight"
            style="@style/Widget.DrugDose1.TextInput"
            android:hint="@string/hint_weight">
            <!--
                TextInputEditText: EditText ottimizzato per TextInputLayout.
                android:inputType="numberDecimal": mostra tastiera numerica con virgola
                android:imeOptions="actionNext": il pulsante della tastiera va al campo successivo
            -->
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_weight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:imeOptions="actionNext" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Campo altezza (obbligatorio solo per BSA) -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_height"
            style="@style/Widget.DrugDose1.TextInput"
            android:hint="@string/hint_height">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_height"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:imeOptions="actionNext" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Campo età (opzionale) -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.DrugDose1.TextInput"
            android:hint="@string/hint_age">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_age"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:imeOptions="actionDone" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Bottone calcola -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_calculate"
            style="@style/Widget.DrugDose1.Button.Primary"
            android:text="@string/btn_calculate" />

        <!--
            Card risultato: inizialmente nascosta (android:visibility="gone").
            Viene mostrata (visibility = VISIBLE) dopo il calcolo riuscito.
            "gone" = non occupa spazio nel layout (diverso da "invisible" che occupa spazio)
        -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_result"
            style="@style/Widget.DrugDose1.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_medium"
            android:visibility="gone">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_card">

                <!-- Etichetta "Risultato" -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_result"
                    android:textStyle="bold"
                    android:textSize="@dimen/text_size_subtitle"
                    android:textColor="@color/color_primary" />

                <!-- Dose calcolata -->
                <TextView
                    android:id="@+id/tv_result"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_small"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:lineSpacingMultiplier="1.3" />

                <!-- Etichetta "Formula applicata" -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_medium"
                    android:text="@string/label_formula_used"
                    android:textStyle="bold"
                    android:textSize="@dimen/text_size_body" />

                <!-- Formula usata per il calcolo -->
                <TextView
                    android:id="@+id/tv_formula_used"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_tiny"
                    android:textSize="@dimen/text_size_body"
                    android:fontFamily="monospace" />

                <!-- Container alert: visibile solo se ci sono alert -->
                <LinearLayout
                    android:id="@+id/layout_alerts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="@dimen/margin_medium"
                    android:visibility="gone">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_alerts"
                        android:textStyle="bold"
                        android:textColor="@color/color_warning"
                        android:textSize="@dimen/text_size_body" />

                    <!-- Testo degli alert clinici -->
                    <TextView
                        android:id="@+id/tv_alerts"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_tiny"
                        android:textColor="@color/color_warning"
                        android:lineSpacingMultiplier="1.4"
                        android:textSize="@dimen/text_size_body" />
                </LinearLayout>

                <!-- Fonte bibliografica -->
                <TextView
                    android:id="@+id/tv_source_ref"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_medium"
                    android:textSize="@dimen/text_size_caption"
                    android:textColor="@color/color_text_secondary"
                    android:fontFamily="monospace" />

                <!-- Bottone salva in cronologia -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_save"
                    style="@style/Widget.DrugDose1.Button.Secondary"
                    android:text="@string/btn_save" />

                <!-- Bottone attiva promemoria -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_reminder"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_small"
                    android:text="@string/btn_reminder"
                    style="@style/Widget.Material3.Button.TonalButton" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>