<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.DrugDose1" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/color_primary</item>
        <item name="colorOnPrimary">@color/color_on_primary</item>
        <item name="colorPrimaryVariant">@color/color_primary_dark</item>
        <item name="colorSecondary">@color/color_secondary</item>
        <item name="android:colorBackground">@color/color_background</item>
        <item name="colorSurface">@color/color_surface</item>
        <item name="colorError">@color/color_error</item>
        <!-- Statusbar: stessa altezza, ma con sfondo primario -->
        <item name="android:statusBarColor">@color/color_primary</item>
    </style>
    <!--
        STILE CARD
        Uno Style raggruppa attributi comuni per evitare duplicazioni nei layout.
        Ogni card nell'app usa questo stile → coerenza visiva garantita.
        Se voglio cambiare l'arrotondamento di tutte le card, lo cambio qui.
    -->
    <style name="Widget.DrugDose1.Card" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">@dimen/card_corner_radius</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="cardBackgroundColor">@color/color_card_background</item>
    </style>
    <!--
        STILE BOTTONE PRIMARIO
        parent="Widget.Material3.Button" → bottone Material3 pieno (sfondo colorato)
    -->
    <style name="Widget.DrugDose1.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/button_height</item>
        <item name="android:layout_marginTop">@dimen/margin_medium</item>
    </style>
    <!--
        STILE BOTTONE SECONDARIO (contorno, senza sfondo colorato)
        parent="Widget.Material3.Button.OutlinedButton"
    -->
    <style name="Widget.DrugDose1.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/button_height</item>
        <item name="android:layout_marginTop">@dimen/margin_small</item>
    </style>
    <!--
        STILE CAMPO DI INPUT (TextInputLayout)
        parent="Widget.Material3.TextInputLayout.OutlinedBox" → campo con bordo
    -->
    <style name="Widget.DrugDose1.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">@dimen/margin_small</item>
    </style>
</resources>